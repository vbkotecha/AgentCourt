# AgentCourt Environment Configuration
# Copy to .env and customize

# Data directory for case storage
AGENTCOURT_DATA_DIR=/data

# Server port (Railway sets this automatically)
PORT=8000

# x402 Payment Configuration (optional - for paid disputes)
# AGENTCOURT_WALLET_ADDRESS=0x...
# CDP_API_KEY_ID=your-key-id
# CDP_API_KEY_SECRET=your-key-secret

# Free tier disputes per month (default: 100)
AGENTCOURT_FREE_TIER=100
